BOT_TOKEN=your_telegram_bot_token_here
ADMIN_CHAT_ID=546485204

# Custom messages (optional — defaults are English)
# {name} is replaced with user's first name in autoreply
# MSG_WELCOME=Welcome to PBS Services! 👋
# MSG_WELCOME_RU=Добро пожаловать в PBS Services! 👋
# MSG_AUTOREPLY=Hi {name}, your message has been forwarded to our team.
# MSG_AUTOREPLY_RU=Здравствуйте, {name}, ваше сообщение было передано нашей команде.
# MSG_SECOND_AUTOREPLY=Thank you for your patience, {name}. A team member will attend to you shortly.
# MSG_SECOND_AUTOREPLY_RU=Спасибо за ваше терпение, {name}. Сотрудник нашей команды скоро ответит вам.

# Delayed second auto-reply (milliseconds, default: 20000 = 20 seconds)
# SECOND_MESSAGE_DELAY_MS=20000
